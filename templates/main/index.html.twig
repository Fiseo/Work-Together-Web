{% extends 'base.html.twig' %}

{% block title %}
    WorkTogether Data Solutions
{% endblock %}

{% block body %}

    <section id="main">
        <div>Infrastructure datacenter &middot; Le Mans, FR</div>
        <h1>Votre infrastructure.<br><em>Notre datacenter.</em></h1>
        <p>
            WorkTogether Data Solutions met a votre disposition 30 baies de datacenter haute disponibilité.
            Location flexible a la baie complete, demi-baie, quart de baie ou unite U.
        </p>
        <div>
            <a href="#pricing">Voir les offres</a>
            <a href="#services">Découvrir les services</a>
        </div>
        <div>
            <div><div>{{ data.availablePercentage}} %</div><div>Unités disponibles</div></div>
            <div><div>{{ data.totalUnit }}</div><div>Unités mises en place</div></div>
            <div><div>99.9%</div><div>Disponibilité</div></div>
            <div><div>24/7</div><div>Supervision</div></div>
        </div>
    </section>

    <section id="services">
        <h2>Une offre modulaire<br>adaptée a votre usage</h2>
        <p>De l'unité individuelle a la baie complete, nous proposons une location flexible avec tous les services essentiels inclus.</p>
        <div>
            <div>
                <span>🌐</span>
                <div>Information consultable</div>
                <p>Une API est disponible pour consulter les informations liées à vos unités.</p>
                <span>Token d'authentification</span>
            </div>
            <div>
                <span>🛜</span>
                <div>Connectivité ultra-rapide</div>
                <p>Liens fibre redondants, faible latence et bande passante garantie pour vos flux de donnees critiques.</p>
                <span>Multi-opérateurs</span>
            </div>
            <div>
                <span>🔒</span>
                <div>Sécurité physique et logique</div>
                <p>Accès controlée par badge, CCTV 24h/24, detection incendie, supervision réseau et SIEM intégré.</p>
                <span>Certification ISO 27001</span>
            </div>
            <div>
                <span>⚡</span>
                <div>Redondance électrique</div>
                <p>Alimentation N+1, groupes électrogènes et onduleurs pour garantir la continuité de vos services.</p>
                <span>Uptime 99.9%</span>
            </div>
        </div>
    </section>

    <section id="pricing">
        <h2>Offres de location</h2>
        <p>Des formules adaptées à chaque taille d'infrastructure, sans engagement minimum.</p>
        <div>
            {% for offer in offers %}
                <div>
                    <div>{{ offer.label }}</div>
                    {% if offer.unitProvided == 1 %}
                        <div>1 unité</div>
                    {% else %}
                        <div>{{ offer.unitProvided}} unités</div>
                    {% endif %}
                    <div>{{ offer.discount*offer.unitProvided }}€ par mois</div>
                    <a href="{{ path('app_booking_new') }}">Choisir</a>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
