{% extends 'base.html.twig' %}

{% block title %}
    WorkTogether Data Solutions
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}

    <section class="hero">
        <div class="hero-top">Infrastructure datacenter · Laval, FR</div>

        <h1 class="hero-title">
            Votre infrastructure.<br>
            <em>Notre datacenter.</em>
        </h1>

        <p class="hero-description">
            WorkTogether Data Solutions met à votre disposition 30 baies de datacenter haute disponibilité.
            Location flexible à la baie complète, demi-baie, quart de baie ou unité U.
        </p>

        <div class="hero-buttons">
            <a href="#pricing" class="btn-primary">Voir les offres</a>
            <a href="#services" class="btn-outline">Découvrir les services</a>
        </div>

        <div class="hero-stats">
            <div class="stat-card">
                <div class="stat-value">{{ data.availablePercentage|number_format(2, ',', ' ') }} %</div>
                <div class="stat-label">Unités disponibles</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">{{ data.totalUnit }}</div>
                <div class="stat-label">Unités mises en place</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">99.9%</div>
                <div class="stat-label">Disponibilité</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">24/7</div>
                <div class="stat-label">Supervision</div>
            </div>
        </div>
    </section>


    <section class="services" id="services">
        <div class="services-container">

            <!-- Left side : titre + description -->
            <div class="services-text">
                <h2>Une offre modulaire adaptée à votre usage</h2>
                <p>
                    De l'unité individuelle à la baie complète, nous proposons une location flexible
                    avec tous les services essentiels inclus. <br>
                    Que vous soyez une startup en pleine croissance,
                    une ETI cherchant à externaliser son infrastructure critique ou un grand compte souhaitant
                    optimiser ses coûts d'hébergement, notre datacenter vous offre une solution sur-mesure,
                    évolutive et sans engagement de longue durée.<br> Chaque espace est conçu pour répondre aux
                    exigences les plus strictes en matière de disponibilité, de sécurité et de performance —
                    avec un accompagnement technique dédié, disponible à tout moment.
                </p>
            </div>

            <!-- Right side : cards -->
            <div class="services-cards">
                <div class="service-card">
                    <div class="service-icon">🌐</div>
                    <div class="service-title">Information consultable</div>
                    <p>Une API est disponible pour consulter les informations liées à vos unités.</p>
                    <small>Token d'authentification</small>
                </div>
                <div class="service-card">
                    <div class="service-icon">🛜</div>
                    <div class="service-title">Connectivité ultra-rapide</div>
                    <p>Liens fibre redondants, faible latence et bande passante garantie pour vos flux de données critiques.</p>
                    <small>Multi-opérateurs</small>
                </div>
                <div class="service-card">
                    <div class="service-icon">🔒</div>
                    <div class="service-title">Sécurité physique et logique</div>
                    <p>Accès contrôlé par badge, CCTV 24h/24, détection incendie, supervision réseau et SIEM intégré.</p>
                    <small>Certification ISO 27001</small>
                </div>
                <div class="service-card">
                    <div class="service-icon">⚡</div>
                    <div class="service-title">Redondance <br> électrique</div>
                    <p>Alimentation N+1, groupes électrogènes et onduleurs pour garantir la continuité de vos services.</p>
                    <small>Uptime 99.9%</small>
                </div>
            </div>

        </div>
    </section>


    <section class="pricing" id="pricing">
        <h2 class="section-title">Offres de location</h2>
        <p class="section-description">
            Des formules adaptées à chaque taille d'infrastructure, sans engagement minimum.
        </p>

        <div class="pricing-grid">
            {% for offer in offers %}
                <div class="pricing-card">
                    <div class="pricing-top">
                        <div class="pricing-title">{{ offer.label }}</div>
                        <div class="pricing-units">
                            {% if offer.unitProvided == 1 %}
                                1 unité
                            {% else %}
                                {{ offer.unitProvided }} unités
                            {% endif %}
                        </div>
                    </div>

                    <div class="pricing-body">
                        {# price first, then description #}
                        <div class="pricing-price">
                            <span class="amount">{{ offer.discount * offer.unitProvided }}€ / mois</span>
                            <small>TVA non incluse</small>
                        </div>

                        {% if offer.description %}
                            <p class="pricing-description">{{ offer.description }}</p>
                        {% endif %}
                    </div>

                    <div class="pricing-actions">
                        <a href="{{ path('app_booking_new') }}" class="btn-primary">Choisir</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>

{% endblock %}
