{% extends 'base.html.twig' %}

{% block title %}
    WorkTogether Data Solutions
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}

    <section class="hero">
        <div class="hero-top">Infrastructure datacenter · Laval, FR</div>

        <h1 class="hero-title">
            Votre infrastructure.<br>
            <em>Notre datacenter.</em>
        </h1>

        <p class="hero-description">
            WorkTogether Data Solutions met à votre disposition 30 baies de datacenter haute disponibilité.
            Location flexible à la baie complète, demi-baie, quart de baie ou unité U.
        </p>

        <div class="hero-buttons">
            <a href="#pricing" class="btn-primary">Voir les offres</a>
            <a href="#services" class="btn-outline">Découvrir les services</a>
        </div>

        <div class="hero-stats">
            <div class="stat-card">
                <div class="stat-value">{{ data.availablePercentage }} %</div>
                <div class="stat-label">Unités disponibles</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">{{ data.totalUnit }}</div>
                <div class="stat-label">Unités mises en place</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">99.9%</div>
                <div class="stat-label">Disponibilité</div>
            </div>

            <div class="stat-card">
                <div class="stat-value">24/7</div>
                <div class="stat-label">Supervision</div>
            </div>
        </div>
    </section>


    <section class="services" id="services">
        <div class="services-container">

            <!-- Left side : titre + description -->
            <div class="services-text">
                <h2>Une offre modulaire adaptée à votre usage</h2>
                <p>De l'unité individuelle à la baie complète, nous proposons une location flexible avec tous les services essentiels inclus.</p>
            </div>

            <!-- Right side : cards -->
            <div class="services-cards">
                <div class="service-card">
                    <div class="service-icon">🌐</div>
                    <div class="service-title">Information consultable</div>
                </div>
                <div class="service-card">
                    <div class="service-icon">🛜</div>
                    <div class="service-title">Connectivité ultra-rapide</div>
                </div>
                <div class="service-card">
                    <div class="service-icon">🔒</div>
                    <div class="service-title">Sécurité physique et logique</div>
                </div>
                <div class="service-card">
                    <div class="service-icon">⚡</div>
                    <div class="service-title">Redondance électrique</div>
                </div>
            </div>

        </div>
    </section>


    <section class="pricing" id="pricing">
        <h2 class="section-title">Offres de location</h2>
        <p class="section-description">
            Des formules adaptées à chaque taille d'infrastructure, sans engagement minimum.
        </p>

        <div class="pricing-grid">
            {% for offer in offers %}
                <div class="pricing-card">
                    <div class="pricing-title">{{ offer.label }}</div>

                    <div class="pricing-units">
                        {% if offer.unitProvided == 1 %}
                            1 unité
                        {% else %}
                            {{ offer.unitProvided }} unités
                        {% endif %}
                    </div>

                    <div class="pricing-price">
                        {{ offer.discount * offer.unitProvided }}€ / mois
                    </div>

                    <a href="{{ path('app_booking_new') }}" class="btn-primary">
                        Choisir
                    </a>
                </div>
            {% endfor %}
        </div>
    </section>

{% endblock %}
