{% extends 'base.html.twig' %}

{% block title %}Commander{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/form.css') }}">
{% endblock %}

{% block body %}
    {{ form_start(form) }}
        <h1>Effectuer une commande</h1>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.offer) }}
            {{ form_widget(form.offer) }}
        </div>
        <div class="form-group toggle-group">
            {{ form_label(form.isMonthly) }}
            <div class="toggle-wrapper">
                {{ form_widget(form.isMonthly) }}
            </div>
        </div>
    </div>
    <button type="submit" class="btn">Commander</button>
    {{ form_end(form) }}
{% endblock %}
